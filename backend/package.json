{
  "name": "@sss/backend",
  "version": "0.1.0",
  "description": "SSS Indexer & REST API — Fastify/Prisma/Pino stack",
  "main": "dist/server.js",
  "scripts": {
    "dev":     "tsx watch src/server.ts",
    "build":   "tsc -p tsconfig.json",
    "start":   "node dist/server.js",
    "prisma":  "prisma",
    "migrate": "prisma migrate dev",
    "studio":  "prisma studio",
    "test":    "vitest run",
    "lint":    "tsc --noEmit"
  },
  "prisma": {
    "schema": "src/db/schema.prisma",
    "seed":   "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor":    "^0.32.1",
    "@fastify/cors":        "^9.0.1",
    "@fastify/helmet":      "^11.1.1",
    "@fastify/jwt":         "^8.0.1",
    "@fastify/rate-limit":  "^9.1.0",
    "@fastify/swagger":     "^8.14.0",
    "@fastify/swagger-ui":  "^3.0.0",
    "@prisma/client":       "^5.13.0",
    "@solana/web3.js":      "^1.98.0",
    "fastify":              "^4.27.0",
    "pino":                 "^9.1.0",
    "pino-pretty":          "^11.1.0",
    "zod":                  "^3.23.8",
    "ioredis":              "^5.3.2",
    "bs58":                 "^5.0.0",
    "dotenv":               "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "prisma":      "^5.13.0",
    "tsx":         "^4.10.0",
    "typescript":  "^5.4.5",
    "vitest":      "^1.6.0"
  }
}
